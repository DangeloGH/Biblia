rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Documento principal do usuário: keyVault cifrado e metadados seguros.
    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      // Subcoleção usada pelo Lectio para marcações, notas e capítulos lidos.
      match /data/{docId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    // Bloqueia qualquer outro caminho por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
